# Copier vers .env (ne pas committer)
# Même base Neon que le repo ETL Projet_Option_BTC (table btc_options)

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Marché (BTC Deribit)
RISK_FREE_RATE=0.0
DIVIDEND_YIELD=0.0

# Filtres données
MIN_OPEN_INTEREST=0.01
MIN_TIME_TO_EXPIRY_DAYS=1
MAX_TIME_TO_EXPIRY_YEARS=1.0
MAX_REL_SPREAD=0.5

# Calibration (SVI / Heston) — poids : vega × √OI
CALIB_USE_VEGA_WEIGHT=true
CALIB_USE_LIQUIDITY_WEIGHT=true
